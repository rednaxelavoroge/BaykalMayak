{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's display name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Stores resort booking information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner of the booking." },
        "checkIn": { "type": "string", "format": "date", "description": "Check-in date." },
        "checkOut": { "type": "string", "format": "date", "description": "Check-out date." },
        "guests": { "type": "integer", "description": "Number of guests." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Booking status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was made." }
      },
      "required": ["uid", "checkIn", "checkOut", "guests", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Booking document."
    }
  }
}
